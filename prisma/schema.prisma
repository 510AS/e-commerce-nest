generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum VendorStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum VendorPlan {
  FREE
  BASIC
  PRO
  PREMIUM
}

enum CheckoutStatus {
  PENDING
  VALIDATED
  PAYMENT_PENDING
  COMPLETED
  FAILED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELLED
}

enum PaymentMethod {
  STRIPE
  PAYPAL
}

enum PromotionType {
  COUPON
  FLASH_SALE
  BUY_X_GET_Y
  FREE_SHIPPING
  TIER
}

enum PromotionScope {
  ORDER
  PRODUCT
  CATEGORY
  VENDOR
  CUSTOMER_GROUP
}

enum StackingRule {
  NONE
  COMBINABLE
  APPLY_BEST
  SEQUENTIAL
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  firstName String
  lastName  String
  role      UserRole  @default(CUSTOMER)
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  addresses Address[]
}

model Address {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  postalCode   String
  country      String
  isDefault    Boolean  @default(false)
  addressType  String   @default("BOTH")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model Vendor {
  id            String              @id @default(uuid())
  userId        String              @unique
  storeName     String
  storeSlug     String              @unique
  description   String?
  logo          String?
  banner        String?
  contactEmail  String?
  contactPhone  String?
  commissionRate Decimal            @default(10.0) @db.Decimal(5, 2)
  status        VendorStatus        @default(PENDING)
  balance       Decimal             @default(0) @db.Decimal(10, 2)
  totalEarnings Decimal             @default(0) @db.Decimal(10, 2)
  subscription  VendorSubscription?
  verification  VendorVerification?
  shippingPolicy VendorShippingPolicy?
  metrics        VendorMetrics?
  commissionRules CommissionRule[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  products      Product[]
  vendorSplits   VendorOrderSplit[]
  promotions     Promotion[]

  @@index([userId])
  @@index([status])
}

model VendorSubscription {
  id          String     @id @default(uuid())
  vendorId    String     @unique
  vendor      Vendor     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  plan        VendorPlan @default(FREE)
  maxProducts Int        @default(10)
  monthlyFee  Decimal    @default(0) @db.Decimal(10, 2)
  startsAt    DateTime   @default(now())
  endsAt      DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum VerificationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum TaxClass {
  GENERAL
  FOOD
  DIGITAL
  CLOTHING
  EXEMPT
}

model VendorVerification {
  id                  String             @id @default(uuid())
  vendorId            String             @unique
  vendor              Vendor             @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  businessLicense     String?
  taxId               String?
  bankAccount         String?
  bankAccountVerified Boolean            @default(false)
  kycStatus           VerificationStatus @default(PENDING)
  reviewedBy          String?
  reviewedAt          DateTime?
  notes               String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model CommissionRule {
  id            String    @id @default(uuid())
  vendorId      String?
  vendor        Vendor?   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id])
  rate          Decimal   @db.Decimal(5, 2)
  minOrderValue Decimal?  @db.Decimal(10, 2)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([vendorId])
  @@index([categoryId])
}

model Category {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  products      Product[]
  commissionRules CommissionRule[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductOwner {
  PLATFORM
  VENDOR
}

model Product {
  id          String           @id @default(uuid())
  name        String
  slug        String           @unique
  description String?
  status      ProductStatus    @default(DRAFT)
  ownerType   ProductOwner     @default(PLATFORM)
  categoryId  String
  category    Category         @relation(fields: [categoryId], references: [id])
  vendorId    String?
  vendor      Vendor?          @relation(fields: [vendorId], references: [id])
  variants    ProductVariant[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
  wishlistItems WishlistItem[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([categoryId])
  @@index([vendorId])
  @@index([status])
  @@index([ownerType])
}

model ProductVariant {
  id        String      @id @default(uuid())
  sku       String      @unique
  productId String
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  options   Json
  inventory Inventory?
  price     ProductPrice?
  cartItems  CartItem[]
  orderItems OrderItem[]
  wishlistItems WishlistItem[]
  waitlistEntries WaitlistEntry[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([productId])
}

model Inventory {
  id            String          @id @default(uuid())
  variantId     String          @unique
  variant       ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity      Int             @default(0)
  reserved      Int             @default(0)
  lowStockAlert Int             @default(5)
  updatedAt     DateTime        @updatedAt
}

model ProductPrice {
  id              String        @id @default(uuid())
  variantId       String        @unique
  variant         ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  price           Decimal       @db.Decimal(10, 2)
  salePrice       Decimal?      @db.Decimal(10, 2)
  saleStartsAt    DateTime?
  saleEndsAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Cart {
  id         String     @id @default(uuid())
  userId     String?
  sessionId  String?
  items      CartItem[]
  couponCode String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([userId])
  @@index([sessionId])
}

model CartItem {
  id         String          @id @default(uuid())
  cartId     String
  cart       Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId  String
  product    Product         @relation(fields: [productId], references: [id])
  variantId  String?
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
  quantity   Int             @default(1)
  priceAtAdd Decimal         @db.Decimal(10, 2)
  ownerType  ProductOwner    @default(PLATFORM)
  vendorId   String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([cartId])
  @@index([productId])
  @@unique([cartId, variantId])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUND_REQUESTED
  REFUNDED
  PARTIALLY_REFUNDED
}

model Checkout {
  id              String         @id @default(uuid())
  userId          String
  cartId          String         @unique
  status          CheckoutStatus @default(PENDING)
  billingAddress  Json
  shippingAddress Json
  shippingMethod  String?
  subtotal        Decimal        @db.Decimal(10, 2)
  shippingAmount  Decimal        @db.Decimal(10, 2) @default(0)
  taxAmount       Decimal        @db.Decimal(10, 2) @default(0)
  discountAmount  Decimal        @db.Decimal(10, 2) @default(0)
  total           Decimal        @db.Decimal(10, 2)
  currencyCode    String         @default("USD")
  idempotencyKey  String?        @unique
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique
  userId          String
  checkoutId      String?     @unique
  status          OrderStatus @default(PENDING)
  subtotal        Decimal     @db.Decimal(10, 2)
  taxAmount       Decimal     @db.Decimal(10, 2)
  shippingAmount  Decimal     @db.Decimal(10, 2)
  discountAmount  Decimal     @db.Decimal(10, 2) @default(0)
  total           Decimal     @db.Decimal(10, 2)
  currencyCode    String      @default("USD")
  platformItemsTotal Decimal? @db.Decimal(10, 2)
  vendorItemsTotal  Decimal? @db.Decimal(10, 2)
  shippingAddress Json
  billingAddress  Json
  shippingMethod  String?
  notes           String?
  idempotencyKey  String?     @unique
  items           OrderItem[]
  timeline        OrderTimeline[]
  payment         Payment?
  shipment        Shipment?
  vendorSplits    VendorOrderSplit[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
}

model OrderItem {
  id          String        @id @default(uuid())
  orderId     String
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product       @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  productName String
  sku         String
  quantity    Int
  unitPrice   Decimal       @db.Decimal(10, 2)
  totalPrice  Decimal       @db.Decimal(10, 2)
  ownerType   ProductOwner  @default(PLATFORM)
  vendorId    String?
  createdAt   DateTime      @default(now())

  @@index([orderId])
}

model OrderTimeline {
  id        String      @id @default(uuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  @@index([orderId])
}

model Payment {
  id                    String        @id @default(uuid())
  orderId               String        @unique
  order                 Order         @relation(fields: [orderId], references: [id])
  amount                Decimal       @db.Decimal(10, 2)
  currencyCode          String        @default("USD")
  method                PaymentMethod @default(STRIPE)
  status                PaymentStatus @default(PENDING)
  stripePaymentIntentId String?
  stripeClientSecret    String?
  metadata              Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([orderId])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  changes    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

enum ShipmentStatus {
  PENDING
  PROCESSING
  SHIPPED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
}

model ShippingMethod {
  id            String   @id @default(uuid())
  name          String
  carrier       String
  estimatedDays Int
  baseRate      Decimal  @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Shipment {
  id             String          @id @default(uuid())
  orderId        String          @unique
  order          Order           @relation(fields: [orderId], references: [id])
  carrier        String
  trackingNumber String?
  trackingUrl    String?
  labelUrl       String?
  status         ShipmentStatus  @default(PENDING)
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum FulfillmentMode {
  VENDOR_SELF
  PLATFORM_MANAGED
  DROPSHIP
}

model VendorShippingPolicy {
  id                 String          @id @default(uuid())
  vendorId           String          @unique
  vendor             Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  fulfillmentMode    FulfillmentMode @default(VENDOR_SELF)
  processingTimeDays Int             @default(2)
  returnPolicy       String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model VendorMetrics {
  id              String  @id @default(uuid())
  vendorId        String  @unique
  vendor          Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  totalSales      Decimal @default(0) @db.Decimal(12, 2)
  totalOrders     Int     @default(0)
  averageRating   Decimal @default(0) @db.Decimal(3, 2)
  responseTimeHrs Decimal @default(0) @db.Decimal(5, 1)
  defectRate      Decimal @default(0) @db.Decimal(5, 2)
  fulfillmentRate Decimal @default(0) @db.Decimal(5, 2)
  updatedAt       DateTime @updatedAt
}

model VendorOrderSplit {
  id              String      @id @default(uuid())
  orderId         String
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vendorId        String
  vendor          Vendor      @relation(fields: [vendorId], references: [id])
  subtotal        Decimal     @db.Decimal(10, 2)
  commission      Decimal     @db.Decimal(10, 2)
  vendorEarnings  Decimal     @db.Decimal(10, 2)
  platformEarnings Decimal    @db.Decimal(10, 2)
  status          OrderStatus @default(PENDING)
  payoutId        String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([orderId])
  @@index([vendorId])
  @@index([status])
}

model TaxRule {
  id       String   @id @default(uuid())
  name     String
  country  String
  state    String?
  zipMin   String?
  zipMax   String?
  rate     Decimal  @db.Decimal(6, 4)
  taxClass TaxClass @default(GENERAL)
  priority Int      @default(0)
  isActive Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([country, state])
  @@index([taxClass])
}

model TaxExemption {
  id                   String             @id @default(uuid())
  userId               String
  taxId                String
  exemptionCertificate String?
  status               VerificationStatus @default(PENDING)
  validUntil           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([userId])
}

model Wishlist {
  id        String          @id @default(uuid())
  userId    String
  name      String          @default("My Wishlist")
  isPublic  Boolean         @default(false)
  shareCode String?         @unique
  items     WishlistItem[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([userId])
}

model WishlistItem {
  id            String   @id @default(uuid())
  wishlistId    String
  wishlist      Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  variantId     String?
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
  priceAtAdd    Decimal  @db.Decimal(10, 2)
  notifyOnPriceDrop Boolean @default(true)
  createdAt     DateTime @default(now())

  @@unique([wishlistId, productId, variantId])
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  PURCHASED
}

model WaitlistEntry {
  id         String         @id @default(uuid())
  variantId  String
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  userId     String
  email      String
  status     WaitlistStatus @default(WAITING)
  notifiedAt DateTime?
  createdAt  DateTime       @default(now())

  @@index([variantId])
  @@index([status])
  @@unique([variantId, userId])
}

model Promotion {
  id            String        @id @default(uuid())
  name          String
  description   String?
  type          PromotionType @default(COUPON)
  code          String?       @unique
  scope         PromotionScope @default(ORDER)
  scopeId       String?
  value         Decimal       @db.Decimal(10, 2)
  valueType     DiscountType  @default(PERCENTAGE)
  minOrderValue Decimal?      @db.Decimal(10, 2)
  maxDiscount   Decimal?      @db.Decimal(10, 2)
  stackingRule  StackingRule  @default(NONE)
  priority      Int           @default(100)
  usageLimit    Int?
  perUserLimit  Int?
  currentUses   Int           @default(0)
  isActive      Boolean       @default(true)
  validFrom     DateTime
  validUntil    DateTime
  conditions    Json?
  vendorId      String?
  vendor        Vendor?       @relation(fields: [vendorId], references: [id])
  usages        PromotionUsage[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([code])
  @@index([type])
  @@index([isActive])
  @@index([validFrom, validUntil])
}

model PromotionUsage {
  id          String    @id @default(uuid())
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  userId      String
  orderId     String?
  usedAt      DateTime  @default(now())

  @@index([promotionId, userId])
  @@unique([promotionId, userId, orderId])
}